@{
    ViewData["Title"] = "Reset Password";
    var memberName = ViewData["MemberName"] as string;
    var memberId = ViewData["MemberId"];
}

<h2 class="section-title">Reset Password</h2>
<p>Set a new password for <strong>@memberName</strong>.</p>

<div class="row"><div class="col-md-6">
    <div asp-validation-summary="All" class="text-danger"></div>
    <form asp-action="ResetPassword" method="post">
        <input type="hidden" name="id" value="@memberId" />
        <div class="mb-3">
            <label class="form-label">New Password</label>
            <input type="password" name="newPassword" class="form-control" required minlength="6" />
        </div>
        <div class="mb-3">
            <label class="form-label">Confirm Password</label>
            <input type="password" name="confirmPassword" class="form-control" required minlength="6" />
        </div>
        <button type="submit" class="btn btn-pldga">Reset Password</button>
        <a asp-action="Edit" asp-route-id="@memberId" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div></div>
