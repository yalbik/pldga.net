@{ ViewData["Title"] = "Admin Dashboard"; }

<h2 class="section-title">🛠️ Admin Dashboard</h2>

<div class="row mb-4">
    <div class="col-md-4 mb-3">
        <div class="card stat-card"><div class="card-body">
            <h6 class="text-muted">Total Members</h6>
            <h3>@ViewData["MemberCount"]</h3>
            <small class="text-success">@ViewData["PaidCount"] paid</small> &middot;
            <small class="text-danger">@ViewData["UnpaidCount"] unpaid</small>
        </div></div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card stat-card"><div class="card-body">
            <h6 class="text-muted">Pending Articles</h6>
            <h3>@ViewData["PendingArticles"]</h3>
        </div></div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card stat-card"><div class="card-body">
            <h6 class="text-muted">Upcoming Events</h6>
            <h3>@ViewData["UpcomingEvents"]</h3>
        </div></div>
    </div>
</div>

<h4 class="mt-4">Quick Actions</h4>
<div class="row">
    <div class="col-md-3 mb-3"><a asp-controller="Members" asp-action="Index" class="btn btn-pldga w-100">👥 Manage Members</a></div>
    <div class="col-md-3 mb-3"><a asp-controller="Events" asp-action="Create" class="btn btn-pldga w-100">📅 Create Event</a></div>
    <div class="col-md-3 mb-3"><a asp-controller="News" asp-action="Pending" class="btn btn-pldga w-100">📋 Review Articles</a></div>
    <div class="col-md-3 mb-3"><a asp-action="Settings" class="btn btn-pldga w-100">⚙️ Site Settings</a></div>
</div>

<div class="mt-3">
    <form asp-action="RecalculatePoints" method="post" class="d-inline">
        <button type="submit" class="btn btn-outline-pldga">🔄 Recalculate Season Points</button>
    </form>
</div>
