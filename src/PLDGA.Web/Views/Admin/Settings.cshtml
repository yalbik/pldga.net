@model SiteSettings
@{ ViewData["Title"] = "Site Settings"; }

<h2 class="section-title">⚙️ Site Settings</h2>

<form asp-action="Settings" method="post">
    <ul class="nav nav-tabs mb-4" role="tablist">
        <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#membership">Membership</a></li>
        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#events">Events</a></li>
        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#leaderboard">Leaderboard</a></li>
        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#polls">Polls</a></li>
        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#news">News</a></li>
        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#appearance">Appearance</a></li>
        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#general">General</a></li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade show active" id="membership">
            <div class="row">
                <div class="col-md-4 mb-3"><label class="form-label">Annual Dues ($)</label><input asp-for="AnnualDuesAmount" type="number" step="0.01" class="form-control" /></div>
                <div class="col-md-4 mb-3"><label class="form-label">Grace Period (days)</label><input asp-for="GracePeriodDays" type="number" class="form-control" /></div>
                <div class="col-md-4 mb-3"><label class="form-label">Late Fee ($)</label><input asp-for="LateFee" type="number" step="0.01" class="form-control" /></div>
            </div>
        </div>

        <div class="tab-pane fade" id="events">
            <div class="row">
                <div class="col-md-4 mb-3"><label class="form-label">Default Reg Deadline (days before)</label><input asp-for="DefaultRegistrationDeadlineDays" type="number" class="form-control" /></div>
                <div class="col-md-4 mb-3"><label class="form-label">Default Max Participants</label><input asp-for="DefaultMaxParticipants" type="number" class="form-control" /></div>
            </div>
        </div>

        <div class="tab-pane fade" id="leaderboard">
            <div class="row">
                <div class="col-md-4 mb-3"><label class="form-label">Top Players on Home</label><input asp-for="TopPlayersOnHomePage" type="number" class="form-control" /></div>
                <div class="col-md-4 mb-3"><div class="form-check mt-4"><input asp-for="ShowRanks" class="form-check-input" /><label class="form-check-label">Show Ranks</label></div></div>
                <div class="col-md-4 mb-3"><div class="form-check mt-4"><input asp-for="ShowEventsPlayed" class="form-check-input" /><label class="form-check-label">Show Events Played</label></div></div>
            </div>
        </div>

        <div class="tab-pane fade" id="polls">
            <div class="row">
                <div class="col-md-4 mb-3"><label class="form-label">Max Poll Answers</label><input asp-for="MaxPollAnswers" type="number" class="form-control" /></div>
                <div class="col-md-4 mb-3"><label class="form-label">Default Duration (days)</label><input asp-for="DefaultPollDurationDays" type="number" class="form-control" /></div>
            </div>
        </div>

        <div class="tab-pane fade" id="news">
            <div class="row">
                <div class="col-md-4 mb-3"><label class="form-label">Max Image Size (MB)</label><input asp-for="MaxImageSizeMb" type="number" class="form-control" /></div>
                <div class="col-md-4 mb-3"><label class="form-label">Allowed Image Formats</label><input asp-for="AllowedImageFormats" class="form-control" /></div>
                <div class="col-md-4 mb-3"><label class="form-label">Articles on Home Page</label><input asp-for="ArticlesOnHomePage" type="number" class="form-control" /></div>
            </div>
        </div>

        <div class="tab-pane fade" id="appearance">
            <div class="row">
                <div class="col-md-6 mb-3"><label class="form-label">Site Title</label><input asp-for="SiteTitle" class="form-control" /></div>
                <div class="col-md-6 mb-3"><label class="form-label">Tagline</label><input asp-for="SiteTagline" class="form-control" /></div>
                <div class="col-md-4 mb-3"><label class="form-label">Primary Color</label><input asp-for="PrimaryColor" type="color" class="form-control form-control-color" /></div>
                <div class="col-md-4 mb-3"><label class="form-label">Secondary Color</label><input asp-for="SecondaryColor" type="color" class="form-control form-control-color" /></div>
                <div class="col-md-12 mb-3"><label class="form-label">Footer Text</label><input asp-for="FooterText" class="form-control" /></div>
                <div class="col-md-6 mb-3"><label class="form-label">Facebook URL</label><input asp-for="FacebookUrl" class="form-control" /></div>
                <div class="col-md-6 mb-3"><label class="form-label">Instagram URL</label><input asp-for="InstagramUrl" class="form-control" /></div>
            </div>
        </div>

        <div class="tab-pane fade" id="general">
            <div class="row">
                <div class="col-md-4 mb-3"><label class="form-label">Current Season Year</label><input asp-for="CurrentSeasonYear" type="number" class="form-control" /></div>
                <div class="col-md-4 mb-3"><label class="form-label">Contact Email</label><input asp-for="ContactEmail" type="email" class="form-control" /></div>
                <div class="col-md-4 mb-3"><label class="form-label">Contact Phone</label><input asp-for="ContactPhone" class="form-control" /></div>
                <div class="col-md-6 mb-3"><label class="form-label">Organization Address</label><input asp-for="OrganizationAddress" class="form-control" /></div>
                <div class="col-md-3 mb-3"><div class="form-check mt-4"><input asp-for="MaintenanceMode" class="form-check-input" /><label class="form-check-label">Maintenance Mode</label></div></div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-pldga">Save Settings</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
