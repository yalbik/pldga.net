@model NewsArticleDto
@{ ViewData["Title"] = Model.Title; }

<article>
    <h2 class="section-title">@Model.Title</h2>
    <p class="text-muted">By @Model.AuthorName &middot; @Model.CreatedDate.ToString("MMMM dd, yyyy") @if(Model.LastModifiedDate.HasValue){ <span>&middot; Updated @Model.LastModifiedDate.Value.ToString("MMM dd, yyyy")</span> }</p>
    @if (Model.ImagePaths.Any())
    {
        <div class="mb-3">
            @foreach (var img in Model.ImagePaths)
            {
                <img src="@img" alt="Article image" class="img-fluid rounded mb-2" style="max-height:400px;" />
            }
        </div>
    }
    <div class="mb-4" style="white-space:pre-wrap;">@Model.Content</div>
</article>
<a asp-action="Index" class="btn btn-outline-pldga">← Back to News</a>
