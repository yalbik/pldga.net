@model IEnumerable<NewsArticleDto>
@{ ViewData["Title"] = "News"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="section-title mb-0">📰 News</h2>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-action="Create" class="btn btn-pldga">+ Write Article</a>
    }
</div>

@if (Model.Any())
{
    <div class="row">
        @foreach (var a in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card card-pldga h-100">
                    @if (a.ImagePaths.Any())
                    {
                        <img src="@a.ImagePaths.First()" class="card-img-top" alt="@a.Title" style="height:200px;object-fit:cover;" />
                    }
                    <div class="card-body">
                        <h5 class="card-title">@a.Title</h5>
                        <p class="text-muted mb-1">By @a.AuthorName &middot; @a.CreatedDate.ToString("MMM dd, yyyy")</p>
                        <p class="card-text">@(a.Content.Length > 150 ? a.Content[..150] + "..." : a.Content)</p>
                        <a asp-action="Details" asp-route-id="@a.Id" class="btn btn-sm btn-outline-pldga">Read More</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <p class="text-muted">No articles published yet.</p>
}
