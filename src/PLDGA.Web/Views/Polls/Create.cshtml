@model CreatePollDto
@{ ViewData["Title"] = "Create Poll"; }

<h2 class="section-title">Create Poll</h2>
<div class="row"><div class="col-md-8">
    <div asp-validation-summary="All" class="text-danger"></div>
    <form asp-action="Create" method="post">
        <div class="mb-3"><label class="form-label">Question</label><input asp-for="Question" class="form-control" required /></div>
        <div class="mb-3">
            <label class="form-label">Answers (min 2, max 10)</label>
            <div id="answers">
                @for (int i = 0; i < 4; i++)
                {
                    <input name="Answers" class="form-control mb-2" placeholder="Answer @(i+1)" />
                }
            </div>
        </div>
        <div class="mb-3"><label class="form-label">End Date (optional)</label><input asp-for="EndDate" type="datetime-local" class="form-control" /></div>
        <button type="submit" class="btn btn-pldga">Create Poll</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div></div>
