@model IEnumerable<PollDto>
@{ ViewData["Title"] = "Polls"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="section-title mb-0">📊 Polls</h2>
    <a asp-action="Create" class="btn btn-pldga">+ Create Poll</a>
</div>

@{ var active = Model.Where(p => p.Status == PollStatus.Active); }
@{ var closed = Model.Where(p => p.Status == PollStatus.Closed); }

@if (active.Any())
{
    <h4>Active Polls</h4>
    <div class="row">
        @foreach (var p in active)
        {
            <div class="col-md-6 mb-3">
                <div class="card card-pldga"><div class="card-body">
                    <h5 class="card-title">@p.Question</h5>
                    <p class="text-muted">By @p.CreatedByName &middot; @p.TotalVotes votes</p>
                    <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-pldga">@(p.HasUserVoted ? "View Results" : "Vote")</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <form asp-action="Close" method="post" class="d-inline"><input type="hidden" name="id" value="@p.Id" /><button class="btn btn-sm btn-outline-warning">Close</button></form>
                    }
                </div></div>
            </div>
        }
    </div>
}

@if (closed.Any())
{
    <h4 class="mt-4">Closed Polls</h4>
    @foreach (var p in closed)
    {
        <div class="card card-pldga mb-2"><div class="card-body py-2">
            <div class="d-flex justify-content-between align-items-center">
                <span>@p.Question <span class="text-muted">(@p.TotalVotes votes)</span></span>
                <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-pldga">View</a>
            </div>
        </div></div>
    }
}
