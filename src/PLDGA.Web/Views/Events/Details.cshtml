@model EventDto
@{
    ViewData["Title"] = Model.Name;
    var allMembers = ViewData["AllMembers"] as List<MemberDto> ?? new();
    var currentMemberId = ViewData["CurrentMemberId"] as Guid?;
    var isRegistered = currentMemberId.HasValue && allMembers.Any(m => m.Id == currentMemberId);
}

<h2 class="section-title">@Model.Name</h2>

<div class="row">
    <div class="col-md-6">
        <div class="card card-pldga mb-4"><div class="card-body">
            <p><strong>Date:</strong> @Model.Date.ToString("MMMM dd, yyyy h:mm tt")</p>
            <p><strong>Location:</strong> @Model.LocationName</p>
            @if (!string.IsNullOrEmpty(Model.LocationAddress)) { <p><strong>Address:</strong> @Model.LocationAddress</p> }
            @if (!string.IsNullOrEmpty(Model.CourseInfo)) { <p><strong>Course:</strong> @Model.CourseInfo</p> }
            <p><strong>Max Participants:</strong> @Model.MaxParticipants</p>
            <p><strong>Registration Deadline:</strong> @Model.RegistrationDeadline.ToString("MMM dd, yyyy")</p>
            <p><strong>Status:</strong> <span class="badge bg-info">@Model.Status</span></p>
            <p><strong>Registered:</strong> @Model.RegisteredCount / @Model.MaxParticipants</p>
        </div></div>

        @if (Model.Status == EventStatus.Upcoming && User.Identity?.IsAuthenticated == true)
        {
            <form asp-action="Register" method="post" class="d-inline">
                <input type="hidden" name="eventId" value="@Model.Id" />
                <button type="submit" class="btn btn-pldga">Register</button>
            </form>
            <form asp-action="Unregister" method="post" class="d-inline ms-2">
                <input type="hidden" name="eventId" value="@Model.Id" />
                <button type="submit" class="btn btn-outline-danger">Unregister</button>
            </form>
        }

        @if (User.IsInRole("Admin"))
        {
            <div class="mt-3">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">Edit</a>
                <a asp-action="RecordResults" asp-route-id="@Model.Id" class="btn btn-outline-pldga btn-sm">Record Results</a>
                <form asp-action="Delete" method="post" class="d-inline">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Delete this event?')">Delete</button>
                </form>
            </div>
        }
    </div>

    <div class="col-md-6">
        @if (Model.Results.Any())
        {
            <h4>Results</h4>
            <table class="table table-hover">
                <thead class="table-light"><tr><th>Place</th><th>Player</th><th>Score</th><th>Points</th></tr></thead>
                <tbody>
                    @foreach (var r in Model.Results)
                    {
                        <tr>
                            <td>@r.Placement</td>
                            <td>@r.MemberName @if (!r.MemberIsPaid) { <span class="badge-unpaid">Unpaid</span> }</td>
                            <td>@r.Score</td>
                            <td>@r.PointsAwarded</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
<a asp-action="Index" class="btn btn-outline-pldga mt-3">← Back to Events</a>
