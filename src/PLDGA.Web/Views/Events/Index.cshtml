@model IEnumerable<EventDto>
@{ ViewData["Title"] = "Events"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="section-title mb-0">📅 Events</h2>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-pldga">+ New Event</a>
    }
</div>

@{ var upcoming = Model.Where(e => e.Status == EventStatus.Upcoming).OrderBy(e => e.Date); }
@{ var completed = Model.Where(e => e.Status == EventStatus.Completed).OrderByDescending(e => e.Date); }

@if (upcoming.Any())
{
    <h4 class="mt-4">Upcoming</h4>
    <div class="row">
        @foreach (var e in upcoming)
        {
            <div class="col-md-6 col-lg-4 mb-3">
                <div class="card card-pldga h-100"><div class="card-body">
                    <h5 class="card-title">@e.Name</h5>
                    <p class="text-muted mb-1">@e.Date.ToString("MMM dd, yyyy")</p>
                    <p class="mb-1">📍 @e.LocationName</p>
                    <p class="mb-2"><small>@e.RegisteredCount / @e.MaxParticipants registered</small></p>
                    <a asp-action="Details" asp-route-id="@e.Id" class="btn btn-sm btn-pldga">Details</a>
                </div></div>
            </div>
        }
    </div>
}

@if (completed.Any())
{
    <h4 class="mt-4">Completed</h4>
    <table class="table table-hover">
        <thead class="table-light"><tr><th>Event</th><th>Date</th><th>Location</th><th>Participants</th><th></th></tr></thead>
        <tbody>
            @foreach (var e in completed)
            {
                <tr>
                    <td>@e.Name</td>
                    <td>@e.Date.ToString("MMM dd, yyyy")</td>
                    <td>@e.LocationName</td>
                    <td>@e.Results.Count</td>
                    <td><a asp-action="Details" asp-route-id="@e.Id" class="btn btn-sm btn-outline-pldga">Results</a></td>
                </tr>
            }
        </tbody>
    </table>
}
